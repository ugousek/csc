    {
      "key": "field_sk_pro_koho_text",
      "label": "Text sekce",
      "name": "pro_koho_text",
      "type": "wysiwyg",
      "toolbar": "full",
      "media_upload": 0,
      "instructions": "Obsah sekce pod hero. Tučný text (B) = bílá barva, zbytek šedý. Prázdné = použije se hlavní Popis školení."
    },

