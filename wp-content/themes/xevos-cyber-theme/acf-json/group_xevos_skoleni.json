{
  "key": "group_xevos_skoleni",
  "title": "Školení – detail",
  "fields": [
    {
      "key": "field_sk_hero_tab",
      "label": "1. Hero",
      "name": "",
      "type": "tab"
    },
    {
      "key": "field_sk_hero_nadpis",
      "label": "Hero nadpis",
      "name": "hero_nadpis",
      "type": "text",
      "instructions": "Nadpis v hero sekci. Text ve &lt;strong&gt; bude růžový (accent). Prázdné = název školení.",
      "placeholder": "Kybernetická bezpečnost - <strong>obecná</strong>"
    },
    {
      "key": "field_sk_hero_obrazek",
      "label": "Hero obrázek",
      "name": "hero_obrazek",
      "type": "image",
      "return_format": "array",
      "preview_size": "medium",
      "instructions": "Obrázek v pravé části hero sekce. Pokud nevyplníte, použije se výchozí."
    },
    {
      "key": "field_sk_hero_popis",
      "label": "Hero popis",
      "name": "hero_popis",
      "type": "textarea",
      "rows": 3,
      "instructions": "Krátký popis pod nadpisem v hero. Tučný text (B) = bílá barva, zbytek šedý. Prázdné = zkrácený hlavní popis.",
      "placeholder": "S novým ZoKB je školení kyberbezpečnosti povinné..."
    },
    {
      "key": "field_sk_popis",
      "label": "Popis školení (pro přehled)",
      "name": "popis",
      "type": "wysiwyg",
      "toolbar": "full",
      "media_upload": 1,
      "tabs": "all",
      "instructions": "Krátký popis zobrazovaný v přehledu/výpisu všech školení (archive). Nemá vliv na hero ani sekci Pro koho."
    },
    {
      "key": "field_sk_cena",
      "label": "Cena bez DPH",
      "name": "cena",
      "type": "number",
      "prepend": "Kč",
      "min": 0
    },
    {
      "key": "field_sk_cena_s_dph",
      "label": "Cena s DPH",
      "name": "cena_s_dph",
      "type": "number",
      "prepend": "Kč",
      "min": 0
    },
    {
      "key": "field_sk_typ",
      "label": "Typ školení",
      "name": "typ",
      "type": "select",
      "choices": {
        "online": "Online",
        "prezencni": "Prezenční",
        "hybrid": "Hybridní"
      },
      "default_value": "prezencni",
      "allow_null": 0
    },

    {
      "key": "field_sk_pro_koho_tab",
      "label": "2. Pro koho",
      "name": "",
      "type": "tab"
    },
    {
      "key": "field_sk_pro_koho_nadpis",
      "label": "Nadpis sekce",
      "name": "pro_koho_nadpis",
      "type": "text",
      "instructions": "Prázdné = Pro koho je školení určeno.",
      "placeholder": "Pro koho je školení určeno"
